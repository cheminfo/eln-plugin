{
  "name": "eln-plugin",
  "version": "0.32.1",
  "description": "Extract metainfo from chemical file formats into a well defined json structure",
  "type": "module",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "npm run tsc && cheminfo-build --entry lib/index.js --root elnPlugin",
    "check-types": "tsc --noEmit",
    "clean": "rimraf lib",
    "eslint": "eslint src",
    "eslint-fix": "npm run eslint -- --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check src",
    "prettier-write": "prettier --write src",
    "test": "npm run test-only && npm run check-types && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage",
    "tsc": "npm run clean && npm run tsc-build",
    "tsc-build": "tsc --project tsconfig.build.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheminfo/eln-plugin.git"
  },
  "author": "Daniel Kostro",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cheminfo/eln-plugin/issues"
  },
  "homepage": "https://github.com/cheminfo/eln-plugin#readme",
  "dependencies": {
    "base64-js": "^1.5.1",
    "genbank-parser": "^3.0.0",
    "jcampconverter": "^12.2.1",
    "netcdf-gcms": "^1.4.0",
    "nmr-metadata": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@zakodium/tsconfig": "^1.0.2",
    "cheminfo-build": "^1.1.11",
    "eslint": "^9.19.0",
    "eslint-config-cheminfo-typescript": "^21.1.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
